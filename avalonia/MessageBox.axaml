<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Ametrin.Utils.Avalonia.MessageBox"
        SizeToContent="Height"
        Width="512"
        Title="Message Box"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto Auto" ColumnDefinitions="Auto *">
        <TextBlock Grid.Row="0" Grid.Column="0" Name="IconLabel" FontFamily="Segoe UI" Text="⚠️" FontSize="80"/>
        <SelectableTextBlock Grid.Row="0" Grid.Column="1" Name="MessageLabel" Margin="16" TextWrapping="Wrap" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="1" Grid.Column="0"  Grid.ColumnSpan="2" Name="ButtonPanel" Margin="16 0 16 16" FlowDirection="RightToLeft" Orientation="Horizontal" Spacing="4"/>
    </Grid>
</Window>
